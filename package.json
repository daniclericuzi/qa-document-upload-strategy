{
  "name": "qa-document-upload-strategy",
  "version": "1.0.0",
  "description": "Test automation for Document Upload & Data Extraction feature",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:api": "jest --testPathPattern=tests/(?!e2e)",
    "test:e2e": "playwright test",
    "test:all": "npm run test & npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.0"
  },
  "dependencies": {
    "express": "^4.18.0",
    "multer": "^1.4.5-lts.1"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e-api-workflow.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ]
  }
}